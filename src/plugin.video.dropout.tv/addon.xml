<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.dropout.tv" name="Dropout TV" version="0.1.0~alpha" provider-name="H3rby7">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.31.0" />
    <import addon="script.module.beautifulsoup4" version="4.12.0" />
    <import addon="script.module.pyjwt" version="2.8.0" />
    <!-- TODO: find appropriate version for "inputstream.adaptive" -->
    <import addon="inputstream.adaptive" version="0.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="python/addon.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Access your dropout.tv content on Kodi</summary>
    <description lang="en_GB">Dropout is an American comedy subscription streaming service. Its ad-free original shows are mainly composed of live play and improv comedy and panel shows. Dropout's series often feature a rotating cast of regular comedians and performers.</description>
    <disclaimer lang="en_GB">Requires a valid dropout.tv subscription!</disclaimer>
    <language>en</language> <!-- (dropout.tv is english content) -->
    <platform>all</platform>
    <license>GPL-3.0-only</license>
    <source>https://github.com/H3rby7/kodi-plugin-dropout-tv</source>
    <news>v0.1.0-SNAPSHOT (15/03/2026)
      [new] work in progress
    </news>
    <assets>
      <icon>resources/icon.png</icon>
      <fanart>resources/fanart.jpg</fanart>
    </assets>
  </extension>
</addon>